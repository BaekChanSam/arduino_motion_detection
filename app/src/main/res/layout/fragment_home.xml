<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="vm"
            type="com.example.myapplication.ui.home.HomeViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/sl_bg"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="14dp">

            <!-- ═════ HEADER ═════ -->
            <LinearLayout
                android:id="@+id/headerRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="12dp"
                android:background="@color/sl_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp">

                    <TextView
                        style="@style/SL.Text.Mono"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sl_back_hq"
                        android:textColor="@color/sl_dim"
                        android:textSize="@dimen/sl_text_caption" />

                    <View
                        android:id="@+id/bleDot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/sl_dot_accent" />

                    <TextView
                        android:id="@+id/bleStatus"
                        style="@style/SL.Text.Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sl_ble_idle"
                        android:textColor="@color/sl_dim"
                        android:textSize="@dimen/sl_text_caption" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/avatar"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/sl_avatar"
                        android:gravity="center"
                        android:text="@string/sl_member_initials"
                        android:textColor="@color/sl_white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_member_id"
                            android:textColor="@color/sl_dim"
                            android:textSize="@dimen/sl_text_caption" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_member_name"
                            android:textColor="@color/sl_text"
                            android:textSize="@dimen/sl_text_xl"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_member_role"
                            android:textColor="@color/sl_dim"
                            android:textSize="@dimen/sl_text_body_sm"
                            android:paddingTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_elapsed_label"
                            android:textColor="@color/sl_white"
                            android:textSize="@dimen/sl_text_mono" />

                        <TextView
                            android:id="@+id/elapsed"
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/sl_text"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ ALERT BANNER ═════ -->
            <FrameLayout
                android:id="@+id/alertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/sl_alert_ok">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/alertIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/sl_alert_icon_ok"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="@color/sl_black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/alertPrio"
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_alert_status_idle"
                            android:textColor="@color/sl_dim"
                            android:textSize="@dimen/sl_text_mono"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <TextView
                            android:id="@+id/alertLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_label_idle"
                            android:textColor="@color/sl_text"
                            android:textSize="@dimen/sl_text_lg"
                            android:textStyle="bold"
                            android:paddingTop="2dp" />

                        <TextView
                            android:id="@+id/alertSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_sub_idle"
                            android:textColor="@color/sl_dim"
                            android:textSize="@dimen/sl_text_body_sm"
                            android:paddingTop="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ═════ BODY DIAGRAM ═════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:background="@drawable/sl_card"
                android:padding="@dimen/sl_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sl_section_body"
                        android:textColor="@color/sl_text"
                        android:textSize="@dimen/sl_text_body"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/SL.Text.Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sl_imu_live"
                        android:textColor="@color/sl_white"
                        android:textSize="@dimen/sl_text_mono" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:background="@drawable/sl_card_inset"
                        android:layout_marginEnd="8dp">

                        <TextView
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginTop="6dp"
                            android:text="@string/sl_view_front"
                            android:textColor="@color/sl_faint"
                            android:textSize="@dimen/sl_text_micro" />

                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_torso"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/bodyHead"
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_head"
                            app:tint="@color/sl_panel_2"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/bodyArmL"
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_arm_l"
                            app:tint="@color/sl_panel_2"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/bodyArmR"
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_arm_r"
                            app:tint="@color/sl_panel_2"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/bodyLegL"
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_leg_l"
                            app:tint="@color/sl_panel_2"
                            android:contentDescription="@null" />

                        <ImageView
                            android:id="@+id/bodyLegR"
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_leg_r"
                            app:tint="@color/sl_panel_2"
                            android:contentDescription="@null" />

                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sl_body_sensors"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="142dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include android:id="@+id/rowHead" layout="@layout/sl_body_row" />
                        <include android:id="@+id/rowArmL" layout="@layout/sl_body_row" />
                        <include android:id="@+id/rowArmR" layout="@layout/sl_body_row" />
                        <include android:id="@+id/rowLegL" layout="@layout/sl_body_row" />
                        <include android:id="@+id/rowLegR" layout="@layout/sl_body_row" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═════ MOTION TIMELINE ═════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/sl_card"
                android:padding="@dimen/sl_card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sl_section_motion"
                        android:textColor="@color/sl_text"
                        android:textSize="@dimen/sl_text_body"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/SL.Text.Mono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sl_axis_now"
                        android:textColor="@color/sl_white"
                        android:textSize="@dimen/sl_text_mono" />
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/activityChart"
                    android:layout_width="match_parent"
                    android:layout_height="120dp" />
            </LinearLayout>

            <!-- ═════ ACTIONS ═════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="14dp">

                <Button
                    android:id="@+id/btnMayday"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/sl_btn_mayday"
                    android:text="@string/sl_btn_mayday"
                    android:textColor="@color/sl_white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:letterSpacing="-0.02"
                    android:elevation="8dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:id="@+id/btnVoice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/sl_btn_action"
                        android:padding="11dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="◐"
                            android:textColor="@color/sl_accent"
                            android:textSize="18sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_voice"
                            android:textColor="@color/sl_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingTop="3dp" />
                        <TextView
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_voice_sub"
                            android:textColor="@color/sl_faint"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/sl_btn_action"
                        android:padding="11dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="◈"
                            android:textColor="@color/sl_accent"
                            android:textSize="18sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_locate"
                            android:textColor="@color/sl_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingTop="3dp" />
                        <TextView
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_locate_sub"
                            android:textColor="@color/sl_faint"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnConnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/sl_btn_action"
                        android:padding="11dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="◉"
                            android:textColor="@color/sl_accent"
                            android:textSize="18sp" />
                        <TextView
                            android:id="@+id/btnConnectLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_connect"
                            android:textColor="@color/sl_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingTop="3dp" />
                        <TextView
                            android:id="@+id/btnConnectSub"
                            style="@style/SL.Text.Mono"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sl_btn_connect_sub"
                            android:textColor="@color/sl_faint"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
